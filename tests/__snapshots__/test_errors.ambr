# serializer version: 1
# name: TestErrorEnvelope.test_schema_snapshot
  dict({
    '$defs': dict({
      'ErrorCode': dict({
        'description': 'Canonical error codes.',
        'enum': list([
          'unknown',
          'invalid_argument',
          'not_found',
          'permission_denied',
          'timeout',
          'tmux_not_found',
          'tmux_version_unsupported',
          'socket_not_found',
          'session_not_found',
          'pane_not_found',
          'pane_dead',
          'command_failed',
          'spawn_failed',
          'detection_failed',
          'capture_failed',
          'pattern_timeout',
          'ssh_connection_failed',
          'ssh_auth_failed',
          'ssh_host_unknown',
          'ssh_timeout',
          'mcp_transport_error',
        ]),
        'title': 'ErrorCode',
        'type': 'string',
      }),
      'ErrorContext': dict({
        'description': 'Which operation and target produced the error.',
        'properties': dict({
          'operation': dict({
            'description': "The operation that failed, e.g. 'capture_pane'",
            'title': 'Operation',
            'type': 'string',
          }),
          'target': dict({
            'anyOf': list([
              dict({
                '$ref': '#/$defs/TargetRef',
              }),
              dict({
                'type': 'null',
              }),
            ]),
            'default': None,
          }),
        }),
        'required': list([
          'operation',
        ]),
        'title': 'ErrorContext',
        'type': 'object',
      }),
      'PaneRef': dict({
        'description': 'Identity of a tmux pane.',
        'properties': dict({
          'id': dict({
            'description': "Tmux pane ID, e.g. '%12'",
            'title': 'Id',
            'type': 'string',
          }),
          'index': dict({
            'description': 'Pane index within its window',
            'title': 'Index',
            'type': 'integer',
          }),
        }),
        'required': list([
          'id',
          'index',
        ]),
        'title': 'PaneRef',
        'type': 'object',
      }),
      'ServerRef': dict({
        'description': '''
          Identity of a tmux server by its socket.
          
          The optional ``host`` field distinguishes remote machines.  When ``None``
          the server is local.  For remote servers the value is the SSH ``Host``
          alias from ``~/.ssh/config`` (e.g. ``"enterprise-a"``).
        ''',
        'properties': dict({
          'host': dict({
            'anyOf': list([
              dict({
                'type': 'string',
              }),
              dict({
                'type': 'null',
              }),
            ]),
            'default': None,
            'description': 'SSH Host alias for remote servers, None for local',
            'title': 'Host',
          }),
          'socket_name': dict({
            'description': "Short socket name, e.g. 'default'",
            'title': 'Socket Name',
            'type': 'string',
          }),
          'socket_path': dict({
            'description': 'Absolute path to the tmux socket, e.g. /tmp/tmux-501/default',
            'title': 'Socket Path',
            'type': 'string',
          }),
        }),
        'required': list([
          'socket_path',
          'socket_name',
        ]),
        'title': 'ServerRef',
        'type': 'object',
      }),
      'SessionRef': dict({
        'description': 'Identity of a tmux session.',
        'properties': dict({
          'id': dict({
            'description': "Tmux session ID, e.g. '$3'",
            'title': 'Id',
            'type': 'string',
          }),
          'name': dict({
            'description': "Session name, e.g. 'auth-refactor'",
            'title': 'Name',
            'type': 'string',
          }),
        }),
        'required': list([
          'id',
          'name',
        ]),
        'title': 'SessionRef',
        'type': 'object',
      }),
      'TargetRef': dict({
        'description': '''
          Full canonical reference for any tmux entity.
          
          All four layers are always present for pane-level references.
          For session-level references, window and pane may be None.
        ''',
        'properties': dict({
          'pane': dict({
            'anyOf': list([
              dict({
                '$ref': '#/$defs/PaneRef',
              }),
              dict({
                'type': 'null',
              }),
            ]),
            'default': None,
          }),
          'server': dict({
            '$ref': '#/$defs/ServerRef',
          }),
          'session': dict({
            'anyOf': list([
              dict({
                '$ref': '#/$defs/SessionRef',
              }),
              dict({
                'type': 'null',
              }),
            ]),
            'default': None,
          }),
          'window': dict({
            'anyOf': list([
              dict({
                '$ref': '#/$defs/WindowRef',
              }),
              dict({
                'type': 'null',
              }),
            ]),
            'default': None,
          }),
        }),
        'required': list([
          'server',
        ]),
        'title': 'TargetRef',
        'type': 'object',
      }),
      'WindowRef': dict({
        'description': 'Identity of a tmux window.',
        'properties': dict({
          'id': dict({
            'description': "Tmux window ID, e.g. '@7'",
            'title': 'Id',
            'type': 'string',
          }),
          'index': dict({
            'description': 'Window index within its session',
            'title': 'Index',
            'type': 'integer',
          }),
          'name': dict({
            'description': "Window name, e.g. 'main'",
            'title': 'Name',
            'type': 'string',
          }),
        }),
        'required': list([
          'id',
          'name',
          'index',
        ]),
        'title': 'WindowRef',
        'type': 'object',
      }),
    }),
    'description': 'Structured error returned by all operations.',
    'properties': dict({
      'code': dict({
        '$ref': '#/$defs/ErrorCode',
      }),
      'context': dict({
        'anyOf': list([
          dict({
            '$ref': '#/$defs/ErrorContext',
          }),
          dict({
            'type': 'null',
          }),
        ]),
        'default': None,
      }),
      'details': dict({
        'additionalProperties': True,
        'title': 'Details',
        'type': 'object',
      }),
      'message': dict({
        'title': 'Message',
        'type': 'string',
      }),
    }),
    'required': list([
      'code',
      'message',
    ]),
    'title': 'ErrorEnvelope',
    'type': 'object',
  })
# ---
